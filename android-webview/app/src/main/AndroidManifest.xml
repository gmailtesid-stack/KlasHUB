<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="KelasHub"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KelasHub"
        android:usesCleartextTraffic="true">
        
        <activity
            android:name=".DashboardActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity android:name=".AdminActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".InputKasActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".InputStudentActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".InputSubjectActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".IzinActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".ManageStudentsActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".RegisterSaaSActivity" android:exported="false" android:screenOrientation="portrait" />
        <activity android:name=".ValidationActivity" android:exported="false" android:screenOrientation="portrait" />
            
    </application>
</manifest>