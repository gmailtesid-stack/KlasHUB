<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PEMBAYARAN KAS KELAS"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Silakan scan atau transfer ke rekening QRIS Bendahara di bawah ini, lalu laporkan mutasi pembayaran Anda."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:id="@+id/ivQris"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:background="@color/zinc_800"
            android:scaleType="centerInside"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jumlah Bayar (Rp)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_bg"
            android:inputType="number"
            android:padding="24dp"
            android:textColor="@color/white"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keterangan (Contoh: Kas Minggu 4)"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/card_bg"
            android:inputType="text"
            android:padding="24dp"
            android:textColor="@color/white"
            android:layout_marginBottom="24dp" />

        <ImageView
            android:id="@+id/ivProofPreview"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:scaleType="centerInside"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSelectProof"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lampirkan Screenshot Resi Transfer"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:padding="24dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitPay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Laporkan Pembayaran"
            app:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="32dp"
            android:padding="20dp"
            android:enabled="true"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Batal / Kembali"
            android:backgroundTint="@color/card_bg"
            android:textColor="@color/white"
            android:padding="24dp"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>



