<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UPLOAD QRIS KELAS"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Silakan unggah foto/screenshot QRIS (GoPay/DANA) pribadi yang akan digunakan sebagai penampung Kas Kelas. Mahasiswa akan mengirimkan uang ke barcode ini."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <ImageView
        android:id="@+id/ivQrisPreview"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="#1E1E1E"
        android:scaleType="centerInside"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_menu_gallery" />

    <Button
        android:id="@+id/btnSelectImage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pilih Gambar dari Galeri"
        android:backgroundTint="#3B82F6"
        android:textColor="@color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnUpload"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Simpan dan Unggah QRIS"
        android:backgroundTint="@color/primary"
        android:textColor="@color/white"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:enabled="false"/>

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Batal / Kembali"
        android:backgroundTint="@color/card_bg"
        android:textColor="@color/white"
        android:padding="16dp"/>
</LinearLayout>
