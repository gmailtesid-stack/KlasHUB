<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="PRESENSI TRACKER"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:letterSpacing="0.02"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pantau kehadiran Anda agar tidak melebihi batas (Maks. 3 pertemuan alfa)."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="32dp" />
        
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAjukanIzin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajukan Izin/Sakit"
        app:backgroundTint="@color/primary"
        android:textColor="@color/white"
        android:fontFamily="sans-serif-black"
        android:padding="20dp"
        app:cornerRadius="32dp"
        app:elevation="4dp"
        android:layout_marginBottom="24dp" />
        
    <ProgressBar
        android:id="@+id/progressAttendance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmptyAttendance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\uD83D\uDCA4 Belum ada pendataan absensi untuk Anda di semester ini."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:background="@color/card_bg"
        android:visibility="gone"
        android:padding="24dp"
        android:gravity="center"
        android:layout_marginTop="24dp" />

    <androidx.recyclerview.widget.RecyclerView android:layoutAnimation="@anim/layout_animation_fall_down"
        android:id="@+id/rvAttendance"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp"/>
</LinearLayout>



